<Window x:Class="ChaiWu.Windows.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ChaiWu.Windows.ViewModels"
        Title="柴务 · 个人财务" Height="700" Width="1000"
        Background="#F5F5F7" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.06" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 冲突 Banner -->
        <Border Grid.Row="0" Background="#FF3B30" CornerRadius="10" Padding="14,10" Margin="0,0,0,12"
                Visibility="{Binding HasConflicts, Converter={StaticResource BoolVis}}"
                Cursor="Hand">
            <Border.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding OpenConflictCenterCommand}"/>
            </Border.InputBindings>
            <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="14"
                       Text="{Binding Conflicts.Count, StringFormat='⚠ 检测到 {0} 条数据冲突，点击处理 →'}"/>
        </Border>

        <!-- 汇总卡片 -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="当前余额" Foreground="#8E8E93" FontSize="13"/>
                    <TextBlock Text="{Binding TotalBalance, StringFormat='¥{0:N2}'}"
                               FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="累计收入" Foreground="#8E8E93" FontSize="13"/>
                    <TextBlock Text="{Binding TotalIncome, StringFormat='¥{0:N2}'}"
                               FontSize="22" FontWeight="SemiBold" Foreground="#34C759" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="累计支出" Foreground="#8E8E93" FontSize="13"/>
                    <TextBlock Text="{Binding TotalExpense, StringFormat='¥{0:N2}'}"
                               FontSize="22" FontWeight="SemiBold" Foreground="#FF3B30" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 流水列表 -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 工具栏 -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" >
                    <TextBlock Text="收支明细" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="+ 新增" Margin="16,0,0,0" Padding="12,6"
                            Background="#007AFF" Foreground="White" BorderThickness="0"
                            Command="{Binding ShowAddDialogCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="手动同步" Margin="8,0,0,0" Padding="12,6"
                            Background="#E5E5EA" BorderThickness="0"
                            Command="{Binding ManualSyncCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- 列表 -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding Transactions}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          BorderThickness="0" Background="Transparent"
                          RowBackground="Transparent" AlternatingRowBackground="#F9F9F9"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                        <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="60"/>
                        <DataGridTextColumn Header="金额" Binding="{Binding Amount, StringFormat='¥{0:N2}'}" Width="100"/>
                        <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="80"/>
                        <DataGridTextColumn Header="备注" Binding="{Binding Note}" Width="*"/>
                        <DataGridTextColumn Header="来源" Binding="{Binding SourceDevice}" Width="120"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Margin" Value="0,1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Type}" Value="收入">
                                    <Setter Property="Foreground" Value="#34C759"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="支出">
                                    <Setter Property="Foreground" Value="#FF3B30"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 状态栏 -->
        <TextBlock Grid.Row="3" Text="{Binding SyncStatus}" FontSize="12"
                   Foreground="#8E8E93" Margin="4,8,0,0"/>
    </Grid>
</Window>
